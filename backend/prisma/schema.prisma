generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  LOCKED
}

enum AccountStatus {
  ACTIVE
  FROZEN
}

enum TransactionStatus {
  PENDING
  APPROVED
  HELD
  BLOCKED
  REJECTED
}

enum RiskDecision {
  APPROVE
  HOLD
  BLOCK
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertSeverity {
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  OPEN
  IN_REVIEW
  RESOLVED
}

enum NotificationChannel {
  EMAIL
  IN_APP
}

enum DeliveryStatus {
  QUEUED
  SENT
  FAILED
}

enum ActorType {
  SYSTEM
  USER
  ANALYST
  ADMIN
}

model User {
  id             String            @id @default(uuid())
  email          String            @unique
  passwordHash   String
  fullName       String
  phone          String?
  status         UserStatus        @default(ACTIVE)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  roles          UserRole[]
  accounts       Account[]
  sessions       Session[]
  notifications  Notification[]
  behaviorProfile BehaviorProfile?
  assignedAlerts Alert[]           @relation("AlertAssignee")
  adminActions   AdminAction[]     @relation("AdminUserActions")
}

model Role {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  userRoles   UserRole[]
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model Session {
  id               String   @id @default(uuid())
  userId           String
  refreshTokenHash String
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id               String        @id @default(uuid())
  userId           String
  accountNumber    String        @unique
  accountType      String
  availableBalance Decimal       @db.Decimal(14, 2)
  ledgerBalance    Decimal       @db.Decimal(14, 2)
  currency         String
  status           AccountStatus @default(ACTIVE)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions     Transaction[]
}

model Transaction {
  id                String            @id @default(uuid())
  accountId         String
  transactionType   String
  amount            Decimal           @db.Decimal(14, 2)
  currency          String
  merchantName      String?
  merchantCategory  String?
  sourceIp          String?
  deviceFingerprint String?
  geoLocation       String?
  status            TransactionStatus @default(PENDING)
  decision          RiskDecision?
  idempotencyKey    String            @unique
  correlationId     String            @unique
  initiatedAt       DateTime          @default(now())
  processedAt       DateTime?
  account           Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  riskAssessment    RiskAssessment?
  fraudSignals      FraudSignal[]
  alert             Alert?
}

model RiskAssessment {
  id              String       @id @default(uuid())
  transactionId   String       @unique
  riskScore       Int
  riskLevel       RiskLevel
  decision        RiskDecision
  modelConfidence Float
  reasonCodes     Json
  assessedAt      DateTime     @default(now())
  transaction     Transaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model FraudSignal {
  id            String      @id @default(uuid())
  transactionId String
  signalType    String
  signalKey     String
  signalValue   Float
  weight        Float
  triggered     Boolean
  createdAt     DateTime    @default(now())
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model BehaviorProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  txCount24h      Int      @default(0)
  avgTxAmount30d  Decimal  @db.Decimal(14, 2)
  commonGeo       String?
  trustedDevices  Json?
  lastUpdatedAt   DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Alert {
  id               String        @id @default(uuid())
  transactionId    String        @unique
  assignedToUserId String?
  severity         AlertSeverity
  status           AlertStatus   @default(OPEN)
  title            String
  description      String
  createdAt        DateTime      @default(now())
  resolvedAt       DateTime?
  transaction      Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  assignedTo       User?         @relation("AlertAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  notifications    Notification[]
  adminActions     AdminAction[]
}

model Notification {
  id             String              @id @default(uuid())
  alertId        String
  userId         String?
  channel        NotificationChannel
  templateKey    String
  deliveryStatus DeliveryStatus      @default(QUEUED)
  sentAt         DateTime?
  alert          Alert               @relation(fields: [alertId], references: [id], onDelete: Cascade)
  user           User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id            String    @id @default(uuid())
  actorType     ActorType
  actorId       String?
  action        String
  entityType    String
  entityId      String
  correlationId String
  metadata      Json
  createdAt     DateTime  @default(now())
}

model FraudRule {
  id            String       @id @default(uuid())
  ruleName      String       @unique
  ruleType      String
  priority      Int
  conditionJson Json
  action        RiskDecision
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model AdminAction {
  id          String   @id @default(uuid())
  adminUserId String
  alertId     String
  actionType  String
  actionNote  String
  createdAt   DateTime @default(now())
  adminUser   User     @relation("AdminUserActions", fields: [adminUserId], references: [id], onDelete: Cascade)
  alert       Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
}
